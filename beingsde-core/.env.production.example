# ==========================================
# BACKEND PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy these keys into your Render or Railway environment settings.

# The port the backend will run on
PORT=8081

# Frontend URL to allow CORS (Vercel URL)
# Example: https://beingsde.vercel.app
APP_BASE_URL=

# MongoDB Connection String (from MongoDB Atlas)
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/beingsde
SPRING_DATA_MONGODB_URI=

# Redis Connection (from Upstash or Render Redis)
# Example: redis://default:<password>@<host>:<port>
SPRING_REDIS_URL=

# Security token secret (Change this to a long random string!)
JWT_SECRET=super_secret_production_key_change_me_immediately_12345678901234567890

# Stripe Secret Key (for payments)
STRIPE_SECRET_KEY=

# Stripe Webhook Secret (for verifying webhook signatures)
STRIPE_WEBHOOK_SECRET=

# Resend API Key (for sending emails)
# Get this from https://resend.com
APP_RESEND_API_KEY=
